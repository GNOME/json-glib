#: json-glib/json-glib-format.c:59
msgid "Prettify output"
msgstr "ຈັດຮູບແບບຜົນລັບໃຫ້ສວຍງາມ"

#: json-glib/json-glib-format.c:60
msgid "Indentation spaces"
msgstr "ຊ່ອງຫວ່າງຂອງການຍະຫວ່າງ"

#: json-glib/json-glib-format.c:60
msgid "SPACES"
msgstr "ຊ່ອງຫວ່າງ"

#: json-glib/json-glib-format.c:61
msgid "Output file"
msgstr "ໄຟລ໌ຜົນລັບ"

#: json-glib/json-glib-format.c:61 json-glib/json-glib-validate.c:108
msgid "FILE"
msgstr "ໄຟລ໌"

#: json-glib/json-glib-format.c:62
msgid "FILE…"
msgstr "ໄຟລ໌…"

#. Translators: the first %s is the program name, the second one
#. * is the URI of the file, the third is the error message.
#.
#: json-glib/json-glib-format.c:88 json-glib/json-glib-format.c:124
#, c-format
msgid "%s: %s: error opening file: %s\n"
msgstr "%s: %s: ເກີດຂໍ້ຜິດພາດໃນການເປີດໄຟລ໌: %s\n"

#. Translators: the first %s is the program name, the second one
#. * is the URI of the file, the third is the error message.
#.
#: json-glib/json-glib-format.c:102 json-glib/json-glib-validate.c:79
#, c-format
msgid "%s: %s: error parsing file: %s\n"
msgstr "%s: %s: ເກີດຂໍ້ຜິດພາດໃນການວິເຄາະໄຟລ໌: %s\n"

#. Translators: the first %s is the program name, the
#. * second one is the URI of the file.
#.
#: json-glib/json-glib-format.c:144
#, c-format
msgid "%s: %s: error writing to stdout"
msgstr "%s: %s: ເກີດຂໍ້ຜິດພາດໃນການຂຽນໃສ່ stdout"

#. Translators: the first %s is the program name, the second one
#. * is the URI of the file, the third is the error message.
#.
#: json-glib/json-glib-format.c:168
#, c-format
msgid "%s: %s: error closing: %s\n"
msgstr "%s: %s: ເກີດຂໍ້ຜິດພາດໃນການປິດ: %s\n"

#. Translators: this message will appear after the usage string
#. and before the list of options.
#: json-glib/json-glib-format.c:204
msgid "Format JSON files."
msgstr "ຈັດຮູບແບບໄຟລ໌ JSON."

#: json-glib/json-glib-format.c:205
msgid "json-glib-format formats JSON resources."
msgstr "json-glib-format ໃຊ້ຈັດຮູບແບບຊັບພະຍາກອນ JSON."

#. Translators: the %s is the program name. This error message
#. * means the user is calling json-glib-validate without any
#. * argument.
#.
#: json-glib/json-glib-format.c:220 json-glib/json-glib-validate.c:129
#, c-format
msgid "Error parsing commandline options: %s\n"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການວິເຄາະຕົວເລືອກຄຳສັ່ງ: %s\n"

#: json-glib/json-glib-format.c:222 json-glib/json-glib-format.c:236
#: json-glib/json-glib-validate.c:131 json-glib/json-glib-validate.c:145
#, c-format
msgid "Try “%s --help” for more information."
msgstr "ລອງ “%s --help” ເພື່ອເບິ່ງຂໍ້ມູນເພີ່ມເຕີມ."

#. Translators: the %s is the program name. This error message
#. * means the user is calling json-glib-validate without any
#. * argument.
#.
#: json-glib/json-glib-format.c:234 json-glib/json-glib-validate.c:143
#, c-format
msgid "%s: missing files"
msgstr "%s: ບໍ່ມີໄຟລ໌"

#. Translators: the first %s is the program name, the second one
#. * is the URI of the file, the third is the error message.
#.
#: json-glib/json-glib-validate.c:64
#, c-format
msgid "%s: %s: error reading file: %s\n"
msgstr "%s: %s: ເກີດຂໍ້ຜິດພາດໃນການອ່ານໄຟລ໌: %s\n"

#. Translators: this message will appear after the usage string
#. and before the list of options.
#: json-glib/json-glib-validate.c:111
msgid "Validate JSON files."
msgstr "ກວດສອບຄວາມຖືກຕ້ອງຂອງໄຟລ໌ JSON."

#: json-glib/json-glib-validate.c:112
msgid "json-glib-validate validates JSON data at the given URI."
msgstr "json-glib-validate ໃຊ້ກວດສອບຄວາມຖືກຕ້ອງຂອງຂໍ້ມູນ JSON ທີ່ URI ທີ່ລະບຸ."

#. translators: the %s is the name of the data structure
#: json-glib/json-gobject.c:930
#, c-format
msgid "Expecting a JSON object, but the root node is of type “%s”"
msgstr "ຄາດວ່າຈະເປັນ object ຂອງ JSON, ແຕ່ node ຫຼັກເປັນປະເພດ “%s”"

#. translators: the '%s' is the type name
#: json-glib/json-gvariant.c:484
#, c-format
msgid "Unexpected type “%s” in JSON node"
msgstr "ພົບປະເພດທີ່ບໍ່ຄາດຄິດ “%s” ໃນ node ຂອງ JSON"

#: json-glib/json-gvariant.c:557
msgid "Missing elements in JSON array to conform to a tuple"
msgstr "ຂາດອົງປະກອບໃນ array ຂອງ JSON ເພື່ອໃຫ້ສອດຄ່ອງກັບ tuple"

#: json-glib/json-gvariant.c:586
msgid "Missing closing symbol “)” in the GVariant tuple type"
msgstr "ຂາດສັນຍາລັກປິດ “)” ໃນປະເພດ tuple ຂອງ GVariant"

#: json-glib/json-gvariant.c:594
msgid "Unexpected extra elements in JSON array"
msgstr "ມີອົງປະກອບເກີນທີ່ບໍ່ຄາດຄິດໃນ array ຂອງ JSON"

#: json-glib/json-gvariant.c:896
msgid "Invalid string value converting to GVariant"
msgstr "ຄ່າສະຕຣິງບໍ່ຖືກຕ້ອງໃນຂະນະທີ່ແປງເປັນ GVariant"

#: json-glib/json-gvariant.c:951
msgid ""
"A GVariant dictionary entry expects a JSON object with exactly one member"
msgstr "ລາຍການ dictionary ຂອງ GVariant ຄາດວ່າຈະເປັນ object ຂອງ JSON ທີ່ມີສະມາຊິກພຽງອັນດຽວເທົ່ານັ້ນ"

#: json-glib/json-gvariant.c:1229
#, c-format
msgid "GVariant class “%c” not supported"
msgstr "ບໍ່ຮອງຮັບຄລາສ GVariant “%c”"

#: json-glib/json-gvariant.c:1283
msgid "Invalid GVariant signature"
msgstr "ລາຍເຊັນ GVariant ບໍ່ຖືກຕ້ອງ"

#: json-glib/json-gvariant.c:1337
msgid "JSON data is empty"
msgstr "ຂໍ້ມູນ JSON ຫວ່າງເປົ່າ"

#. translators: %s: is the file name, the first %d is the line
#. * number, the second %d is the position on the line, and %s is
#. * the error message
#.
#: json-glib/json-parser.c:1180
#, c-format
msgid "%s:%d:%d: Parse error: %s"
msgstr "%s:%d:%d: ຂໍ້ຜິດພາດໃນການວິເຄາະ: %s"

#: json-glib/json-parser.c:1261
msgid "JSON data must be UTF-8 encoded"
msgstr "ຂໍ້ມູນ JSON ຕ້ອງຖືກເຂົ້າລະຫັດເປັນ UTF-8"

#: json-glib/json-path.c:391
msgid "Only one root node is allowed in a JSONPath expression"
msgstr "ອະນຸຍາດໃຫ້ມີ node ຫຼັກພຽງອັນດຽວໃນສຳນວນ JSONPath"

#. translators: the %c is the invalid character
#: json-glib/json-path.c:400
#, c-format
msgid "Root node followed by invalid character “%c”"
msgstr "Node ຫຼັກຕາມດ້ວຍຕົວອັກສອນທີ່ບໍ່ຖືກຕ້ອງ “%c”"

#: json-glib/json-path.c:440
msgid "Missing member name or wildcard after . character"
msgstr "ຂາດຊື່ສະມາຊິກ ຫຼື wildcard ຫຼັງຈາກເຄື່ອງໝາຍຈຸດ (.)"

#: json-glib/json-path.c:514
#, c-format
msgid "Malformed slice expression “%*s”"
msgstr "ສຳນວນ slice “%*s” ມີຮູບແບບບໍ່ຖືກຕ້ອງ"

#: json-glib/json-path.c:558
#, c-format
msgid "Invalid set definition “%*s”"
msgstr "ການກຳນົດ set “%*s” ບໍ່ຖືກຕ້ອງ"

#: json-glib/json-path.c:611
#, c-format
msgid "Invalid slice definition “%*s”"
msgstr "ການກຳນົດ slice “%*s” ບໍ່ຖືກຕ້ອງ"

#: json-glib/json-path.c:639
#, c-format
msgid "Invalid array index definition “%*s”"
msgstr "ການກຳນົດ index ຂອງ array “%*s” ບໍ່ຖືກຕ້ອງ"

#: json-glib/json-path.c:658
#, c-format
msgid "Invalid first character “%c”"
msgstr "ຕົວອັກສອນທຳອິດ “%c” ບໍ່ຖືກຕ້ອງ"

#: json-glib/json-reader.c:522
#, c-format
msgid "The current node is of type “%s”, but an array or an object was expected."
msgstr "The node ປັດຈຸບັນເປັນປະເພດ “%s”, ແຕ່ຄາດວ່າຈະເປັນ array ຫຼື object."

#: json-glib/json-reader.c:534
#, c-format
msgid ""
"The index “%d” is greater than the size of the array at the current position."
msgstr "The index “%d” ມີຄ່າຫຼາຍກວ່າຂະໜາດຂອງ array ທີ່ຕຳແໜ່ງປັດຈຸບັນ."

#: json-glib/json-reader.c:551
#, c-format
msgid "The index “%d” is greater than the size of the object at the current position."
msgstr "The index “%d” ແມ່ນມີຄ່າຫຼາຍກວ່າຂະໜາດຂອງ object ທີ່ຕຳແໜ່ງປັດຈຸບັນ."

#: json-glib/json-reader.c:634 json-glib/json-reader.c:807
#: json-glib/json-reader.c:856 json-glib/json-reader.c:895
#: json-glib/json-reader.c:935 json-glib/json-reader.c:975
#: json-glib/json-reader.c:1015 json-glib/json-reader.c:1062
#: json-glib/json-reader.c:1100 json-glib/json-reader.c:1128
msgid "No node available at the current position"
msgstr "ບໍ່ມີ node ທີ່ຕຳແໜ່ງປັດຈຸບັນ"

#: json-glib/json-reader.c:641
#, c-format
msgid "The current position holds a “%s” and not an array"
msgstr "ຕຳແໜ່ງປັດຈຸບັນເປັນ “%s” ບໍ່ແມ່ນ array"

#: json-glib/json-reader.c:723
#, c-format
msgid "The current node is of type “%s”, but an object was expected."
msgstr "The node ປັດຈຸບັນເປັນປະເພດ “%s”, ແຕ່ຄາດວ່າຈະເປັນ object."

#: json-glib/json-reader.c:730
#, c-format
msgid "The member “%s” is not defined in the object at the current position."
msgstr "ສະມາຊິກ “%s” ບໍ່ໄດ້ຖືກກຳນົດໃນ object ທີ່ຕຳແໜ່ງປັດຈຸບັນ."

#: json-glib/json-reader.c:814 json-glib/json-reader.c:863
#, c-format
msgid "The current position holds a “%s” and not an object"
msgstr "ຕຳແໜ່ງປັດຈຸບັນເປັນ “%s” ບໍ່ແມ່ນ object"

#: json-glib/json-reader.c:904 json-glib/json-reader.c:944
#: json-glib/json-reader.c:984 json-glib/json-reader.c:1024
#: json-glib/json-reader.c:1071
#, c-format
msgid "The current position holds a “%s” and not a value"
msgstr "ຕຳແໜ່ງປັດຈຸບັນເປັນ “%s” ບໍ່ແມ່ນຄ່າ"

#: json-glib/json-reader.c:1032
msgid "The current position does not hold a string type"
msgstr "ຕຳແໜ່ງປັດຈຸບັນບໍ່ແມ່ນປະເພດສະຕຣິງ"
